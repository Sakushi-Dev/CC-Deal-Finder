# ---------------------------------------------------------------------------
# Autonomous trader configuration (LOCAL ONLY — never commit the real .env)
# Copy this file to ".env" and fill in your values.
# ---------------------------------------------------------------------------

# --- Solana RPC -------------------------------------------------------------
# Any mainnet RPC endpoint. The public one works for testing but is rate
# limited; for real use prefer Helius / QuickNode / Triton.
TRADER_RPC_URL=https://api.mainnet-beta.solana.com

# --- Wallet -----------------------------------------------------------------
# DRY-RUN: a public address is enough to read balances / available volume.
TRADER_WALLET_ADDRESS=

# LIVE: the wallet's private key (base58, as exported from Phantom:
# Settings -> Security & Privacy -> Export Private Key). Leave EMPTY for
# dry-run. When set, the bot can sign transactions itself — treat this like
# cash. Use a dedicated, separately funded wallet only.
TRADER_WALLET_SECRET=

# --- Master safety switch ---------------------------------------------------
# Must be exactly "true" to allow ANY real on-chain spending. Anything else
# keeps the bot in dry-run (simulation) mode.
TRADER_LIVE=false

# --- Budget / volume --------------------------------------------------------
# USDC kept untouched (never spent). "available volume" = USDC balance - reserve.
TRADER_RESERVE_USDC=0
# SOL kept for transaction fees.
TRADER_GAS_RESERVE_SOL=0.05

# --- Quantity-first sizing --------------------------------------------------
# Default per-card price cap. Quantity over quality -> keep this low so the
# bot accumulates many cheap cards.
TRADER_BASE_MAX_CARD_USD=100
# Only buy when the ask is at least this % below the CC insured value.
# 0 = buy anything at/below insured value.
TRADER_MIN_DISCOUNT_PCT=0

# --- Volume allocation (direct buys vs. offers) -----------------------------
# How the available volume is split between instant purchases and standing
# buy orders (offers). These are percentages of the available volume; if they
# sum to more than 100, they are scaled down proportionally.
TRADER_DIRECT_BUY_PCT=100
TRADER_OFFER_PCT=0
# How far BELOW the current ask price an offer (bid) is placed, in percent.
# Example: 10 = offer 10% under the listed price.
TRADER_OFFER_DISCOUNT_PCT=10
# Offers ignore the minimum discount, but a listing priced more than this far
# ABOVE market value is skipped: such sellers expect a profit and rarely accept
# a lowball offer. Example: 10 = only bid on listings asking <= market +10%.
TRADER_OFFER_MAX_PREMIUM_PCT=10

# --- Resale -----------------------------------------------------------------
# Sell rule: bought cards are relisted this far BELOW their insured market
# value, so the listing stays attractive while still locking in a margin.
# Keep it smaller than the buy discount so every flip is profitable
# (e.g. buy at -30%, resell at -10%).
TRADER_RESELL_DISCOUNT_PCT=10

# --- Escalation protocol ----------------------------------------------------
# When available volume >= this, the per-card cap is raised so the bot may
# also grab expensive cards.
TRADER_ESCALATION_VOLUME_USD=1000
# Raised per-card cap while escalation is active.
TRADER_ESCALATION_MAX_CARD_USD=1000

# --- Sourcing ---------------------------------------------------------------
# Comma-separated categories to scan ("" = all). Example: Pokemon,One Piece
TRADER_CATEGORIES=
# Max marketplace pages to scan per cycle.
TRADER_MAX_PAGES=10
# Comma-separated marketplaces to ACCEPT. CC only by default — Magic Eden
# (ME) listings are ignored.
TRADER_ALLOWED_MARKETPLACES=CC

# --- Loop -------------------------------------------------------------------
# Wait (seconds) between automatic cycles when the loop is running. The loop
# itself runs indefinitely until you stop it; this is only the spacing.
TRADER_LOOP_INTERVAL_SEC=300
