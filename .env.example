# ---------------------------------------------------------------------------
# Autonomous trader — CONNECTION & SECURITY only (LOCAL ONLY, never commit .env)
# Copy this file to ".env" and fill in your values.
#
# Strategy tuning (sizing, allocation, resale, risk limits, sourcing, loop
# interval) does NOT live here anymore. Those defaults ship in
# "trader_settings.example.json" — copy it to "trader_settings.json" or edit
# them live from the /trader dashboard. This file holds only the variables that
# are security-sensitive or define the connection, so a glance shows what the
# bot connects to and what could move real funds.
#
# Precedence: trader_settings.json (UI/file) overrides any value still set in
# the environment; security variables below are read from the environment ONLY.
# ---------------------------------------------------------------------------

# --- Solana RPC (connection) ------------------------------------------------
# Any mainnet RPC endpoint. The public one works for testing but is rate
# limited; for real use prefer Helius / QuickNode / Triton. Kept here so the
# connection is visible at a glance (some providers embed an API key in the URL).
TRADER_RPC_URL=https://api.mainnet-beta.solana.com

# --- Wallet (connection) ----------------------------------------------------
# DRY-RUN: a public address is enough to read balances / available volume.
TRADER_WALLET_ADDRESS=

# --- Wallet secret (SECURITY) -----------------------------------------------
# LIVE only: the wallet's private key (base58, exported from Phantom:
# Settings -> Security & Privacy -> Export Private Key). Leave EMPTY for
# dry-run. When set, the bot can sign transactions itself — treat this like
# cash. Use a dedicated, separately funded wallet only. ENV-ONLY: never read
# from the settings file or editable in the UI.
TRADER_WALLET_SECRET=

# --- Master safety switch (SECURITY) ----------------------------------------
# Must be exactly "true" to allow ANY real on-chain spending. Anything else
# keeps the bot in dry-run (simulation) mode. ENV-ONLY, never UI-editable.
TRADER_LIVE=false

# --- Authentication (SECURITY) ----------------------------------------------
# CollectorCrypt trading session provider: "none" (default, no live trading),
# "privy" (SIWS) or "static" (paste a token, integration testing). ENV-ONLY.
TRADER_AUTH_PROVIDER=none
# Privy application id, required when TRADER_AUTH_PROVIDER=privy.
TRADER_PRIVY_APP_ID=
# Pre-obtained CC session token, used when TRADER_AUTH_PROVIDER=static.
TRADER_CC_TOKEN=

# --- Crash recovery (SECURITY-adjacent) -------------------------------------
# When exactly "true", a loop that was running before a restart/crash is
# resumed automatically — in the SAME mode it was configured in (it never
# arms live trading by itself; TRADER_LIVE / auth still gate that). ENV-ONLY
# so a crash can never silently change trading behaviour. Default off.
TRADER_AUTO_RESUME=false
